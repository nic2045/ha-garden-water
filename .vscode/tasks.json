{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Check Dotfiles Setup",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/.vscode/check-dotfiles.sh", "${workspaceFolder}"],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
